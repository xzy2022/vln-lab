+def discover_scans(scans_dir, connectivity_dir):
+    if scans_dir:
+        return sorted(os.listdir(scans_dir))
+
+    scans_txt = os.path.join(connectivity_dir, 'scans.txt')
+    if os.path.exists(scans_txt):
+        with open(scans_txt, 'r') as f:
+            return [
+                line.strip()
+                for line in f
+                if line.strip()
+            ]
+
+    suffix = '_connectivity.json'
+    return sorted(
+        filename[:-len(suffix)]
+        for filename in os.listdir(connectivity_dir)
+        if filename.endswith(suffix)
+    )
+
+connectivity_dir = args.connectivity_dir or os.path.join(os.path.dirname(__file__), 'connectivity')
+scans = discover_scans(args.scans_dir, connectivity_dir)
+graphs, paths, distances = load_nav_graphs(scans, connectivity_dir=connectivity_dir)
 
