+    def save_eval_items_sidecars(
+        self,
+        results,
+        output_dir,
+        item_metrics=None,
+        score_summary=None,
+        dataset_name=None,
+        split=None,
+        official_results_filename=None,
+        experiment_id=None,
+    ):
+        dataset_name = dataset_name or self.source
+        if dataset_name not in {"R2R", "REVERIE", "CVDN", "SOON"}:
+            return None
+
+        split = split or self.split
+        simulation_env = self._eval_item_simulation_env()
+        success_threshold_m = 3.0
+        official_results_filename = official_results_filename or f"{dataset_name}_{split}_results.json"
+        items_filename = f"{dataset_name}_{split}_eval_items.jsonl"
+        context_filename = f"{dataset_name}_{split}_eval_context.json"
+
+        os.makedirs(output_dir, exist_ok=True)
+        items_path = os.path.join(output_dir, items_filename)
+        context_path = os.path.join(output_dir, context_filename)
+
+        annotations = {item['instr_id']: item for item in self.alldata}
+        metric_rows = self._eval_item_metric_rows(item_metrics, len(results))
+        rows = []
+        seen_ids = set()
+
+        for index, pred in enumerate(results):
+            internal_item_id = pred['instr_id']
+            if internal_item_id in seen_ids:
+                raise ValueError(f"Duplicate eval item internal_item_id: {internal_item_id}")
+            seen_ids.add(internal_item_id)
+
+            if internal_item_id not in annotations:
+                raise KeyError(f"Prediction instr_id {internal_item_id} is missing from dataset annotations")
+
+            ann = annotations[internal_item_id]
+            row = self._build_eval_item_row(
+                dataset_name=dataset_name,
+                split=split,
+                simulation_env=simulation_env,
+                success_threshold_m=success_threshold_m,
+                pred=pred,
+                ann=ann,
+                metric_row=metric_rows[index],
+            )
+            if row['prediction']['trajectory'] and row['prediction']['trajectory'][0] != row['annotation']['start_viewpoint']:
+                raise ValueError(
+                    f"Eval item {internal_item_id} starts at {row['prediction']['trajectory'][0]}, "
+                    f"expected {row['annotation']['start_viewpoint']}"
+                )
+            rows.append(self._eval_item_json_ready(row))
+
+        if len(rows) != len(results):
+            raise ValueError(f"Eval item row count {len(rows)} does not match prediction count {len(results)}")
+
+        self._validate_eval_item_aggregates(dataset_name, rows, score_summary)
+
+        context = {
+            'schema_version': 'eval_context.v1',
+            'items_schema_version': 'eval_items.v2',
+            'run_context': {
+                'framework': 'SAME',
+                'experiment_id': experiment_id if experiment_id is not None else self._eval_item_experiment_id(),
+                'dataset': dataset_name,
+                'split': split,
+                'simulation_env': simulation_env,
+                'success_threshold_m': success_threshold_m,
+            },
+            'files': {
+                'official_results': official_results_filename,
+                'eval_items': items_filename,
+            },
+            'counts': {
+                'predictions': len(results),
+                'items': len(rows),
+                'unique_internal_item_ids': len(seen_ids),
+            },
+            'score_summary': score_summary or {},
+        }
+
+        with open(context_path, 'w') as fout:
+            json.dump(self._eval_item_json_ready(context), fout, ensure_ascii=False, indent=2)
+
+        with open(items_path, 'w') as fout:
+            for row in rows:
+                fout.write(json.dumps(row, ensure_ascii=False) + '\n')
+
+        return {
+            'context_path': context_path,
+            'items_path': items_path,
+        }
