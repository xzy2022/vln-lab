+                    'graph_distance_m': graph_distance_m,
+                    'graph_hops': graph_hops,
+                    'is_current_visible': vp in visible_by_vp if vp is not None else False,
+                    'point_id': visible_by_vp.get(vp, {}).get('pointId') if vp is not None else None,
+                    'global': self._score_pair(global_logits, global_probs, i, idx),
+                    'fused': self._score_pair(fused_logits, fused_probs, i, idx),
+                })
+
+            local_candidates = []
+            local_vpids = nav_inputs['vp_cand_vpids'][i]
+            for idx, vp in enumerate(local_vpids):
+                valid = self._bool_value(nav_inputs['vp_nav_masks'][i, idx])
+                cand = ob.get('candidate', [])[idx - 1] if idx > 0 and idx - 1 < len(ob.get('candidate', [])) else {}
+                local_candidates.append({
+                    'index': idx,
