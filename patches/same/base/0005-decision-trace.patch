+    def _experiment_flag(self, name, default=False):
+        experiment = getattr(self.args, 'experiment', None)
+        if experiment is None:
+            return default
+        if isinstance(experiment, dict):
+            return bool(experiment.get(name, default))
+        return bool(getattr(experiment, name, default))
+
+    def _decision_trace_enabled(self):
+        return self._experiment_flag('decision_trace', False)
+
+    def _moe_trace_enabled(self):
+        return self._experiment_flag('moe_trace', False)
+
+    @staticmethod
+    def _finite_float(value):
+        try:
+            value = float(value)
+        except (TypeError, ValueError):
+            return None
+        return value if math.isfinite(value) else None
+
+    @staticmethod
+    def _tensor_float(tensor, *indices):
+        if tensor is None:
+            return None
+        try:
+            value = tensor.detach()
+            if indices:
+                value = value[indices]
+            return DUETAgent._finite_float(value.item())
+        except (AttributeError, IndexError, RuntimeError, TypeError, ValueError):
+            return None
+
+    @staticmethod
+    def _bool_value(value):
+        try:
+            if hasattr(value, 'detach'):
+                return bool(value.detach().cpu().item())
+            return bool(value)
+        except (RuntimeError, TypeError, ValueError):
+            return False
+
+    @staticmethod
+    def _int_value(value):
+        try:
+            if hasattr(value, 'detach'):
+                return int(value.detach().cpu().item())
+            return int(value)
+        except (RuntimeError, TypeError, ValueError):
+            return None
+
+    def _score_pair(self, logits, probs, sample_index, action_index):
+        return {
+            'logit': self._tensor_float(logits, sample_index, action_index),
+            'prob': self._tensor_float(probs, sample_index, action_index),
+        }
+
+    def _graph_route(self, gmap, current_viewpoint, target_viewpoint):
+        if target_viewpoint is None:
+            return [current_viewpoint]
+        try:
+            return [current_viewpoint] + list(gmap.graph.path(current_viewpoint, target_viewpoint))
+        except Exception:
+            return [current_viewpoint, target_viewpoint]
+
+    def _router_logits_for_sample(self, router_logits, sample_index, batch_size):
+        if router_logits is None:
+            return None
+        if router_logits.dim() == 2 and router_logits.size(0) == batch_size:
+            return router_logits[sample_index].view(1, -1)
+        if router_logits.dim() == 2 and router_logits.size(0) % batch_size == 0:
+            return router_logits.view(batch_size, -1, router_logits.size(-1))[sample_index]
+        if router_logits.dim() == 3 and router_logits.size(0) == batch_size:
+            return router_logits[sample_index].view(-1, router_logits.size(-1))
+        return None
+
+    def _build_moe_trace(self, nav_outs, sample_index, batch_size):
+        if not self._moe_trace_enabled():
+            return None
+
+        sample_probs = []
+        for router_key in ('global_router_logits', 'local_router_logits'):
+            router_collection = nav_outs.get(router_key)
+            if router_collection is None:
+                continue
+            for router_logits in router_collection:
+                sample_logits = self._router_logits_for_sample(router_logits, sample_index, batch_size)
+                if sample_logits is None:
+                    continue
+                probs = torch.softmax(sample_logits.float(), dim=-1)
+                sample_probs.append(probs.detach().cpu())
+
+        if not sample_probs:
+            return None
+
+        mean_probs = torch.cat(sample_probs, dim=0).mean(dim=0)
+        entropy = -torch.sum(mean_probs * torch.log(mean_probs.clamp_min(1e-12)))
+        top_k = min(int(getattr(self.args.model, 'num_experts_per_tok', 2)), mean_probs.numel())
+        top_probs, top_indices = torch.topk(mean_probs, top_k)
+        return {
+            'expert_probs_mean': [self._finite_float(x) for x in mean_probs.tolist()],
+            'top_experts': [int(x) for x in top_indices.tolist()],
+            'top_expert_probs': [self._finite_float(x) for x in top_probs.tolist()],
+            'router_entropy': self._finite_float(entropy.item()),
+        }
+
+    def _append_decision_trace(
+        self,
+        *,
+        step,
+        obs,
+        gmaps,
+        traj,
+        nav_inputs,
+        nav_outs,
+        nav_logits,
+        nav_probs,
+        nav_vpids,
+        a_t,
+        a_t_stop,
+        cpu_a_t,
+        ended,
+        max_action_len,
+    ):
+        batch_size = len(obs)
+        global_logits = nav_outs['global_logits']
+        local_logits = nav_outs['local_logits']
+        fused_logits = nav_outs['fused_logits']
+        global_probs = torch.softmax(global_logits, 1)
+        local_probs = torch.softmax(local_logits, 1)
+        fused_probs = torch.softmax(fused_logits, 1)
+
+        for i, ob in enumerate(obs):
+            if self._bool_value(ended[i]):
+                continue
+            if 'decision_trace' not in traj[i]:
+                continue
+
+            selected_index = self._int_value(a_t[i])
+            selected_viewpoint = None
+            if selected_index is not None and 0 <= selected_index < len(nav_vpids[i]):
+                selected_viewpoint = nav_vpids[i][selected_index]
+
+            current_viewpoint = ob['viewpoint']
+            visible_by_vp = {cand['viewpointId']: cand for cand in ob.get('candidate', [])}
+            executed_viewpoint = cpu_a_t[i]
+            if executed_viewpoint is None:
+                selection_kind = 'stop'
+            elif executed_viewpoint in visible_by_vp:
+                selection_kind = 'current_visible'
+            else:
+                selection_kind = 'global_node'
+
+            stop_reason = None
+            if executed_viewpoint is None:
+                if self._bool_value(a_t_stop[i]):
+                    stop_reason = 'model_stop'
+                elif nav_inputs['no_vp_left'][i]:
+                    stop_reason = 'no_vp_left'
+                elif step == max_action_len - 1:
+                    stop_reason = 'max_action_len'
+                else:
+                    stop_reason = 'forced_stop'
+
+            route_viewpoints = self._graph_route(gmaps[i], current_viewpoint, executed_viewpoint)
+            gmap_vpids = nav_inputs['gmap_vpids'][i]
+            gmap_index_by_vp = {
+                vp: idx for idx, vp in enumerate(gmap_vpids)
+                if vp is not None and vp not in gmap_vpids[:idx]
+            }
+
+            gmap_candidates = []
+            for idx, vp in enumerate(gmap_vpids):
+                valid = self._bool_value(nav_inputs['gmap_masks'][i, idx])
+                visited = self._bool_value(nav_inputs['gmap_visited_masks'][i, idx])
+                if vp is None:
+                    graph_distance_m = None
+                    graph_hops = None
+                    route = [current_viewpoint]
+                else:
+                    route = self._graph_route(gmaps[i], current_viewpoint, vp)
+                    graph_distance_m = self._finite_float(gmaps[i].graph.distance(current_viewpoint, vp))
+                    graph_hops = max(len(route) - 1, 0)
+                gmap_candidates.append({
+                    'index': idx,
+                    'viewpoint': vp,
