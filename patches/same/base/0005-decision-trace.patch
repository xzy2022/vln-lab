+                    'normalized_heading': self._finite_float(cand.get('normalized_heading')),
+                    'normalized_elevation': self._finite_float(cand.get('normalized_elevation')),
+                    'distance_m': self._finite_float(cand.get('distance')),
+                    'local': self._score_pair(local_logits, local_probs, i, idx),
+                })
+
+            visible_candidates = []
+            for cand_index, cand in enumerate(ob.get('candidate', []), start=1):
+                vp = cand['viewpointId']
+                gmap_index = gmap_index_by_vp.get(vp)
+                visible_candidates.append({
+                    'local_index': cand_index,
+                    'gmap_index': gmap_index,
+                    'viewpoint': vp,
+                    'point_id': cand.get('pointId'),
+                    'heading': self._finite_float(cand.get('heading')),
+                    'elevation': self._finite_float(cand.get('elevation')),
+                    'normalized_heading': self._finite_float(cand.get('normalized_heading')),
