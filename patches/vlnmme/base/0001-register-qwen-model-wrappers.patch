diff --git a/src/models/model_path_resolver.py b/src/models/model_path_resolver.py
new file mode 100644
index 0000000..71b2ecc
--- /dev/null
+++ b/src/models/model_path_resolver.py
@@ -0,0 +1,149 @@
+import os
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+
+def _discover_repo_root() -> Path:
+    current = Path(__file__).resolve()
+    for parent in current.parents:
+        if (parent / "configs" / "global").is_dir():
+            return parent
+    return current.parents[4]
+
+
+REPO_ROOT = _discover_repo_root()
+DEFAULT_GLOBAL_CONFIG_DIRS = (
+    REPO_ROOT / "configs" / "global" / "lab",
+    REPO_ROOT / "configs" / "global" / "local",
+)
+
+
+@dataclass(frozen=True)
+class ConfiguredModelPath:
+    model_key: str
+    path: Path
+    paths_config: Path
+    models_config: Path
+
+
+def _resolve_repo_path(path_value: str | Path) -> Path:
+    path = Path(path_value)
+    if path.is_absolute():
+        return path
+    return (REPO_ROOT / path).resolve(strict=False)
+
+
+def _load_yaml_mapping(path: Path) -> dict[str, Any]:
+    with path.open("r", encoding="utf-8") as handle:
+        data = yaml.safe_load(handle)
+    if not isinstance(data, dict):
+        raise ValueError(f"{path} must contain a YAML object")
+    return data
+
+
+def _resolve_mount_root(paths_config: Path, root_key: str, path_side: str) -> Path:
+    paths = _load_yaml_mapping(paths_config)
+
+    mounts = paths.get("mounts")
+    if not isinstance(mounts, dict):
+        raise ValueError(f"{paths_config} must contain a mounts mapping")
+
+    mount = mounts.get(root_key)
+    if not isinstance(mount, dict):
+        raise KeyError(f"{paths_config} has no mounts.{root_key}")
+
+    raw_root = mount.get(path_side)
+    if not raw_root:
+        raise KeyError(f"{paths_config} has no mounts.{root_key}.{path_side}")
+
+    root = Path(os.path.expandvars(os.path.expanduser(str(raw_root))))
+    if root.is_absolute():
+        return root
+
+    project_root = paths.get("project_root")
+    if not project_root:
+        raise KeyError(f"{paths_config} has no project_root")
+    return (Path(str(project_root)) / root).resolve(strict=False)
+
+
+def _iter_config_pairs():
+    global_config_dir = os.environ.get("VLN_LAB_GLOBAL_CONFIG_DIR")
+    explicit_paths_config = os.environ.get("VLN_LAB_PATHS_CONFIG")
+    explicit_models_config = os.environ.get("VLN_LAB_MODELS_CONFIG")
+
+    if explicit_paths_config or explicit_models_config:
+        paths_config = (
+            _resolve_repo_path(explicit_paths_config)
+            if explicit_paths_config
+            else _resolve_repo_path(Path(explicit_models_config).with_name("paths.yaml"))
+        )
+        models_config = (
+            _resolve_repo_path(explicit_models_config)
+            if explicit_models_config
+            else _resolve_repo_path(Path(explicit_paths_config).with_name("models.yaml"))
+        )
+        yield paths_config, models_config
+        return
+
+    if global_config_dir:
+        config_dir = _resolve_repo_path(global_config_dir)
+        yield config_dir / "paths.yaml", config_dir / "models.yaml"
+        return
+
+    for config_dir in DEFAULT_GLOBAL_CONFIG_DIRS:
+        yield config_dir / "paths.yaml", config_dir / "models.yaml"
+
+
+def resolve_configured_model_path(model_key: str | None) -> ConfiguredModelPath | None:
+    if not model_key:
+        return None
+
+    path_side = os.environ.get("VLN_LAB_PATH_SIDE", "container")
+
+    for paths_config, models_config in _iter_config_pairs():
+        if not paths_config.is_file() or not models_config.is_file():
+            continue
+
+        models_data = _load_yaml_mapping(models_config)
+        models = models_data.get("models")
+        if not isinstance(models, dict):
+            raise ValueError(f"{models_config} must contain a models mapping")
+
+        model = models.get(model_key)
+        if not isinstance(model, dict):
+            continue
+
+        root_key = model.get("root")
+        relpath = model.get("relpath")
+        if not root_key or not relpath:
+            raise KeyError(f"{models_config} models.{model_key} needs root and relpath")
+
+        relpath = Path(os.path.expandvars(os.path.expanduser(str(relpath))))
+        if relpath.is_absolute():
+            resolved_path = relpath
+        else:
+            resolved_path = _resolve_mount_root(paths_config, str(root_key), path_side) / relpath
+
+        return ConfiguredModelPath(
+            model_key=model_key,
+            path=resolved_path,
+            paths_config=paths_config,
+            models_config=models_config,
+        )
+
+    return None
+
+
+def resolve_model_name_or_path(model_name: str, model_key: str | None = None) -> str:
+    configured = resolve_configured_model_path(model_key)
+    if configured is None:
+        return model_name
+    if not configured.path.exists():
+        raise FileNotFoundError(
+            f"Configured path for model key '{configured.model_key}' does not exist: "
+            f"{configured.path} (from {configured.models_config})"
+        )
+    return str(configured.path)
