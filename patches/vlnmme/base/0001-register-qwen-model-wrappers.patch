diff --git a/src/models/qwen3_5.py b/src/models/qwen3_5.py
new file mode 100644
index 0000000..ffdd133
--- /dev/null
+++ b/src/models/qwen3_5.py
@@ -0,0 +1,113 @@
+import json
+import os
+from pathlib import Path
+import torch
+from transformers import AutoModelForCausalLM, AutoTokenizer
+from typing import Any, Mapping
+
+from models.base_mllm import BaseMLLM
+
+
+class Qwen3_5(BaseMLLM):
+    model_name = "Qwen/Qwen3.5-4B"
+    local_model_dir = None
+
+    def __init__(
+        self,
+        max_length: int = 512,
+    ):
+        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
+        print(f"Using device: {self.device}")
+
+        model_name = self._resolve_model_name()
+        try:
+            self.tokenizer = AutoTokenizer.from_pretrained(model_name, trust_remote_code=True)
+            self.model = AutoModelForCausalLM.from_pretrained(
+                model_name,
+                torch_dtype="auto",
+                device_map="auto",
+                trust_remote_code=True,
+            )
+
+            self.model.eval()
+            print(f"Successfully loaded Qwen text model: {model_name}")
+        except Exception as e:
+            raise OSError(self._format_load_error(model_name, e))
+
+        self.max_length = max_length
+
+    def _resolve_model_name(self):
+        candidate_name = self.local_model_dir or self.model_name.rsplit("/", 1)[-1]
+        candidate_roots = [
+            os.environ.get("VLN_LAB_MODELS_DIR"),
+            "/workspace/vln-lab/external/models",
+            Path(__file__).resolve().parents[3] / "external" / "models",
+            "/data/E/share/models",
+        ]
+        for root in candidate_roots:
+            if not root:
+                continue
+            candidate = Path(root) / candidate_name
+            if candidate.exists():
+                return str(candidate)
+        return self.model_name
+
+    def _format_load_error(self, model_name, error):
+        detail = f"Failed to load Qwen text model ({model_name}): {error}"
+        config_path = Path(model_name) / "config.json"
+        if config_path.exists():
+            try:
+                model_type = json.loads(config_path.read_text(encoding="utf-8")).get("model_type")
+            except Exception:
+                model_type = None
+            if model_type == "qwen3_5":
+                detail += (
+                    "\nThis checkpoint uses model_type 'qwen3_5'. The current "
+                    "Transformers runtime must include Qwen3.5 support, or the "
+                    "model must be served via a compatible backend such as "
+                    "SGLang/vLLM and called through an API wrapper."
+                )
+        return detail
+
+    @property
+    def _identifying_params(self) -> Mapping[str, Any]:
+        return {
+            "ckpt": self.model.config._name_or_path,
+            "max_length": self.max_length,
+            "modality": "text",
+        }
+
+    def _construct_input(self, prompt: str):
+        if getattr(self.tokenizer, "chat_template", None):
+            messages = [
+                {
+                    "role": "user",
+                    "content": prompt,
+                }
+            ]
+            text = self.tokenizer.apply_chat_template(
+                messages,
+                tokenize=False,
+                add_generation_prompt=True,
+            )
+        else:
+            text = prompt
+        return self.tokenizer([text], return_tensors="pt").to(self.model.device)
+
+    def __call__(self, input: dict, prompt: str) -> str:
+        self.model.eval()
+        with torch.no_grad():
+            inputs = self._construct_input(prompt)
+            generated_ids = self.model.generate(
+                **inputs,
+                max_new_tokens=self.max_length,
+            )
+            generated_ids_trimmed = [
+                out_ids[len(in_ids) :] for in_ids, out_ids in zip(inputs.input_ids, generated_ids)
+            ]
+            output_text = self.tokenizer.batch_decode(
+                generated_ids_trimmed,
+                skip_special_tokens=True,
+                clean_up_tokenization_spaces=False,
+            )
+            return output_text[0]
